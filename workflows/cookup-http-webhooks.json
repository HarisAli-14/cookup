    {
      "parameters": {
        "jsCode": "// Extract order ID from the chef's reply message\n// The original message contains \"Order ID: CK-XXXXXX\"\nconst replyToMessage = $input.item.json.message.reply_to_message;\nif (replyToMessage && replyToMessage.text) {\n  const match = replyToMessage.text.match(/Order ID: (CK-\\d+)/);\n  if (match) {\n    return [{ order_id: match[1], chef_reply: $input.item.json.message.text }];\n  }\n}\n// Fallback: get the most recent pending proposal\nreturn [{ order_id: null, chef_reply: $input.item.json.message.text }];"
      },
