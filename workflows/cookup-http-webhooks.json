      "parameters": {
        "promptType": "define",
        "text": "=You are the CookUp AI meal planner. Create a meal proposal based on customer request and available recipes.\n\nCustomer request:\n{{ $(\"Parse Customer Request\").item.json.output }}\n\nAvailable recipes:\n{{ $(\"Fetch Available Recipes\").all().map(r => JSON.stringify(r.json)).join(\"\\n\") }}\n\nRules:\n1. STRICTLY filter out recipes with restricted ingredients\n2. If customer says \"no beef\", exclude ALL recipes with \"beef\" in tags\n3. If customer needs gluten-free, include at least one recipe with \"gluten-free\" tag\n4. Select combination for the number of people requested\n5. Assign chef based on recipes\n\nReturn ONLY valid JSON:\n{\n  \"proposal_summary\": \"3x Chicken Biryani Bowls and 1x Gluten-Free Lentil Bowl\",\n  \"items\": [\n    {\"recipe\": \"Chicken Biryani Bowl\", \"quantity\": 3},\n    {\"recipe\": \"Gluten-Free Lentil Bowl\", \"quantity\": 1}\n  ],\n  \"chef\": \"Chef Ayesha\",\n  \"delivery_time\": \"7:30 PM\",\n  \"reasoning\": \"Meets no-beef and gluten-free requirements.\"\n}",
        "options": {
          "systemMessage": "You are a meal planner. Return only valid JSON, no markdown, no explanation."
        }
      },
